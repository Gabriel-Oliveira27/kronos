generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Papel {
  ADMIN
  SUPORTE
  CONFIGURADOR_ESCALA
  USUARIO
}

enum TipoDiaEscala {
  NORMAL
  PLANTAO
  HOME_OFFICE
  FOLGA
  // SABADO_REDUZIDO removido — não faz parte das regras de negócio (ver migration)
}

enum Visibilidade {
  PUBLICO
  PRIVADO
}

model Usuario {
  id              String   @id @default(cuid())
  nomeCompleto    String
  setor           String
  email           String?  @unique
  username        String   @unique
  senhaHash       String
  papel           Papel    @default(USUARIO)
  ativo           Boolean  @default(true)
  temApp          Boolean  @default(false)
  // Usuário-fantasma: criado avulso pela tela de escala só para completar a
  // escala; não usa o sistema. `origem = "escala"` marca essa procedência.
  ehGhost         Boolean  @default(false)
  origem          String?
  fotoUrl         String?
  temaBase        String?  // "claro" | "escuro" | "noturno" | "system"
  corDestaque     String?
  temaConfig      Json?    // { textColor, borderColor, activeColor, secondaryColor }
  modeloHorarioId String?
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  escalas        EscalaDia[]
  conhecimentos  ConhecimentoItem[]
  registrosPonto RegistroPonto[]
  logs           LogEvento[]
  modeloHorario  ModeloHorario?   @relation(fields: [modeloHorarioId], references: [id])

  @@map("usuarios")
}

model SolicitacaoAcesso {
  id           String   @id @default(cuid())
  nomeCompleto String
  setor        String
  email        String?
  observacoes  String?
  status       String   @default("pendente")
  criadoEm     DateTime @default(now())

  @@map("solicitacoes_acesso")
}

model EscalaDia {
  id           String        @id @default(cuid())
  usuarioId    String
  usuario      Usuario       @relation(fields: [usuarioId], references: [id])
  data         DateTime
  tipo         TipoDiaEscala
  observacao   String?
  criadoPorId  String
  atualizadoEm DateTime      @updatedAt

  @@index([usuarioId, data])
  @@map("escalas_dia")
}

model ConhecimentoItem {
  id           String       @id @default(cuid())
  autorId      String
  autor        Usuario      @relation(fields: [autorId], references: [id])
  titulo       String
  conteudo     String
  categoria    String?
  tags         String[]
  visibilidade Visibilidade @default(PRIVADO)
  deletadoEm   DateTime?
  atualizadoEm DateTime     @updatedAt
  criadoEm     DateTime     @default(now())

  @@index([autorId])
  @@index([visibilidade])
  @@map("conhecimento_itens")
}

model RegistroPonto {
  id           String    @id @default(cuid())
  usuarioId    String
  usuario      Usuario   @relation(fields: [usuarioId], references: [id])
  data         DateTime
  tipoEvento   String
  horarioReal  String?
  confirmado   Boolean   @default(false)
  origem       String    @default("app") // "app" | "web"
  deletadoEm   DateTime?
  atualizadoEm DateTime  @updatedAt

  @@index([usuarioId, data])
  @@map("registros_ponto")
}

model RegistroExcluido {
  id            String   @id @default(cuid())
  tabelaOrigem  String
  registroId    String
  payload       Json
  excluidoPorId String
  excluidoEm    DateTime @default(now())

  @@map("registros_excluidos")
}

model LogEvento {
  id        String   @id @default(cuid())
  usuarioId String?
  usuario   Usuario? @relation(fields: [usuarioId], references: [id])
  tipo      String
  detalhe   Json?
  criadoEm  DateTime @default(now())

  @@index([tipo])
  @@index([criadoEm])
  @@map("logs_evento")
}

// Configuração global do app mobile (singleton, id = "global"). Gerenciada pela
// Dev Area (somente ADMIN). Guarda textos das notificações e o pool/parâmetros
// das notificações aleatórias — vale para todos os dispositivos.
model ConfiguracaoApp {
  id              String   @id @default("global")
  config          Json
  atualizadoPorId String?
  atualizadoEm    DateTime @updatedAt

  @@map("configuracao_app")
}

// Setores gerenciados pelo admin: lista canônica usada para vincular usuários
// (o Usuario.setor guarda o nome) e para recortar as escalas por setor. Cada
// setor pode ter uma palavra secreta própria (hash) para a escala pública.
model Setor {
  id                 String   @id @default(cuid())
  nome               String   @unique
  palavraSecretaHash String?
  criadoEm           DateTime @default(now())
  atualizadoEm       DateTime @updatedAt

  @@map("setores")
}

model ModeloHorario {
  id            String   @id @default(cuid())
  nome          String
  descricao     String?
  horasSemanais Float    @default(44)
  jornadaDiaria Float    @default(8)
  configuracao  Json?    // { diasUteis: { seg: 8, ter: 8, ... }, avisos: [{hora, mensagem}] }
  criadoPorId   String
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  usuarios      Usuario[]

  @@map("modelos_horario")
}
